# ==============================================
# MailPilot Backend Environment Variables
# ==============================================
# Copy this file to .env in the backend/ directory
# and fill in your actual values before running.

# PostgreSQL (Supabase)
SUPABASE_JDBC_URL=jdbc:postgresql://db.xxx.supabase.co:5432/postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-db-password

# JWT Secret (min 32 characters recommended)
JWT_SECRET=your-very-long-random-jwt-secret-key-here

# AES-256 Encryption Key (exactly 32 bytes) & IV (exactly 16 bytes)
# Used to encrypt/decrypt Gmail App Passwords
ENCRYPTION_SECRET_KEY=Your32ByteEncryptionKeyHere!!
ENCRYPTION_IV=DefaultInitVec123456

